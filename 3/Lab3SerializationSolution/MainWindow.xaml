<Window x:Class="SerializationApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Serialization Lab"
        Height="600"
        Width="900">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">

            <ComboBox x:Name="TypeComboBox"
                      Width="200"
                      Margin="0 0 10 0"/>

            <TextBox x:Name="NameTextBox"
                     Width="150"
                     Margin="0 0 10 0"
                     Text="Name"/>

            <TextBox x:Name="AgeTextBox"
                     Width="80"
                     Margin="0 0 10 0"
                     Text="20"/>

            <Button Content="Add"
                    Width="100"
                    Margin="0 0 10 0"
                    Click="Add_Click"/>

            <Button Content="Delete"
                    Width="100"
                    Margin="0 0 10 0"
                    Click="Delete_Click"/>

            <Button Content="Save JSON"
                    Width="120"
                    Margin="0 0 10 0"
                    Click="Save_Click"/>

            <Button Content="Load JSON"
                    Width="120"
                    Click="Load_Click"/>

        </StackPanel>

        <ListBox x:Name="PeopleListBox"
                 Grid.Row="1"/>

        <TextBlock Grid.Row="2"
                   Margin="0 10 0 0"
                   Text="Lab 3 - Object Serialization"/>
    </Grid>
</Window>
